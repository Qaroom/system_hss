  <!-- Kamera linkini kutunun ön yüzüne sabitliyoruz -->
  <!-- Burada kutu dönmüyor, sadece sensörün yönü rpy ile ayarlanıyor -->
  <joint name="camera_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_spin_link"/>
    <origin xyz="0.005 0 0.008" rpy="0 3.1415 0"/> <!-- 90° pitch yukarı baktırıyor -->
  </joint>


<!-- ///////////////////////// gazebo  parameters////////////////////////////-->

    <gazebo reference="camera_spin_link">
        <sensor name="camera" type="camera">
         <pose>0 0 0 0 1.57 1.57</pose> <!-- roll pitch yaw -->
            <always_on>true</always_on>
            <update_rate>60</update_rate>        <!-- FPS -->
            <visualize>true</visualize>
            <camera>
            <horizontal_fov>1.047</horizontal_fov> <!-- 60 derece -->
            <image>
                <width>640</width>
                <height>480</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.1</near>
                <far>100</far>
            </clip>
            </camera>
            <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors"/>
           
            <topic>camera/image</topic> <!-- Gazebo topic -->
        </sensor>
    </gazebo>








  
